{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vorber",
  "version": "0.1.6",
  "identifier": "com.isso.vorber",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vorber",
        "width": 800,
        "height": 648,
        "minWidth": 800,
        "minHeight": 648,
        "maxWidth": 800,
        "maxHeight": 648,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
